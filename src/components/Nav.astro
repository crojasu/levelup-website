---
const campaigns = [
  {
    name: 'Media Guidelines',
    slug: 'media-guidelines-domestic-abuse',
    links: [
      { label: 'Sign the petition', href: 'https://levelup.yourmovement.org/p/dignity-for-dead-women' },
      { label: 'Resources', href: '/all-resources' },
    ]
  },
  {
    name: 'Pregnancy in Prison',
    slug: 'pregnancy-in-prison',
    links: [
      { label: 'Sign the petition', href: 'https://levelup.yourmovement.org/p/pregnancy-in-prison' },
      { label: 'Resources', href: '/all-resources' },
      { label: 'Legal Toolkit', href: '/all-resources' },
    ]
  },
  {
    name: 'Sexual Violence in Football',
    slug: 'sexual-violence-in-football',
    links: [
      { label: 'Sign the petition', href: 'https://levelup.yourmovement.org/p/sexual-violence-in-football' },
      { label: 'Share your story', href: '/contact' },
    ]
  },
  {
    name: 'Abortion is Healthcare',
    slug: 'abortion-is-healthcare',
    links: [
      { label: 'Sign the petition', href: 'https://levelup.yourmovement.org/p/abortion-is-healthcare' },
      { label: 'Abortion Stories', href: 'https://welevelup.org/abortion-stories-complete/' },
      { label: 'Resources', href: '/all-resources' },
    ]
  },
  {
    name: 'No More Lyes',
    slug: 'nomorelyes',
    links: [
      { label: 'Sign the petition', href: 'https://levelup.yourmovement.org/p/no-more-lyes' },
      { label: 'Relaxer Info Kit', href: '/all-resources' },
      { label: "Open letter to L'Oréal", href: 'https://welevelup.org/nomorelyes-open-letter-to-loreal/' },
      { label: 'Share your hair story', href: '/contact' },
    ]
  },
  {
    name: 'We Protect Us',
    slug: 'we-protect-us',
    links: [
      { label: 'Sign up for trainings', href: '/active-campaigns/we-protect-us' },
    ]
  },
];
---

<header id="nav-header">
  <div id="nav-inner">

    <!-- Logo -->
    <a href="/" id="nav-logo" aria-label="We Level Up home">
      <span class="logo-we">WE</span>
      <span class="logo-level">LEVEL UP</span>
    </a>

    <!-- Centre links -->
    <nav id="nav-menu" aria-label="Main navigation">

      <div class="nav-item">
        <a href="/about-us" class="nav-link">About Us</a>
      </div>

      <div class="nav-item has-mega">
        <button class="nav-link nav-trigger" aria-expanded="false">
          Campaigns
          <svg class="nav-caret" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M1 1l4 4 4-4"/>
          </svg>
        </button>
        <div class="mega-panel" role="region">
          <div class="mega-inner">
            {campaigns.map(c => (
              <div class="mega-col">
                <a href={`/active-campaigns/${c.slug}`} class="mega-title">{c.name}</a>
                {c.links.map(l => (
                  <a href={l.href} class="mega-link">{l.label}</a>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="nav-item">
        <a href="/all-resources" class="nav-link">Resources</a>
      </div>

      <div class="nav-item">
        <a href="/blog" class="nav-link">Blog</a>
      </div>

      <div class="nav-item">
        <a href="/press" class="nav-link">Press</a>
      </div>

      <div class="nav-item has-mega">
        <button class="nav-link nav-trigger" aria-expanded="false">
          Community
          <svg class="nav-caret" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M1 1l4 4 4-4"/>
          </svg>
        </button>
        <div class="mega-panel" role="region">
          <div class="mega-inner" style="grid-template-columns: 1fr 1fr;">
            <div class="mega-col">
              <a href="/active-campaigns/we-protect-us" class="mega-title">We Protect Us</a>
              <a href="/active-campaigns/we-protect-us" class="mega-link">Free bystander training</a>
              <a href="/contact" class="mega-link">Join the community</a>
            </div>
            <div class="mega-col">
              <a href="/contact" class="mega-title">Get Involved</a>
              <a href="/contact" class="mega-link">Join as a member</a>
              <a href="/donate" class="mega-link">Support our work</a>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <a href="/contact" class="nav-link">Contact</a>
      </div>

    </nav>

    <!-- CTAs -->
    <div id="nav-actions">
      <a href="/donate" class="cta-donate">Donate</a>
      <a href="/contact" class="cta-join">Join Us</a>
    </div>

    <!-- Mobile toggle -->
    <button id="mobile-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

  </div>
</header>

<style>
  /* ── Variables ── */
  :root {
    --navy: #0D0D3B;
    --lime: #C8FF00;
    --cream: #E8E4D4;
    --purple: #7B6FA0;
    --nav-h: 68px;
  }

  /* ── Shell ── */
  #nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--cream);
    border-bottom: 1.5px solid rgba(13,13,59,0.08);
    backdrop-filter: blur(8px);
  }

  #nav-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 28px;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* ── Logo ── */
  #nav-logo {
    display: flex;
    align-items: center;
    gap: 3px;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 40px;
  }

  .logo-we {
    font-size: 1rem;
    font-weight: 900;
    color: var(--navy);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .logo-level {
    font-size: 1rem;
    font-weight: 900;
    color: var(--navy);
    background: var(--lime);
    padding: 3px 6px 2px;
    letter-spacing: -0.02em;
    line-height: 1;
    display: block;
  }

  /* ── Nav menu ── */
  #nav-menu {
    display: flex;
    align-items: stretch;
    gap: 0;
    flex: 1;
    height: 100%;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: stretch;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0 14px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
    border-bottom: 2px solid transparent;
    margin-bottom: -1.5px; /* align with header border */
  }

  .nav-link:hover,
  .nav-item.open .nav-link {
    color: var(--navy);
    border-bottom-color: var(--lime);
  }

  .nav-caret {
    width: 9px;
    height: 6px;
    transition: transform 0.2s;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .nav-item.open .nav-caret {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* ── Dropdown panels ── */
  .mega-panel {
    display: none;
    position: absolute;
    top: calc(100% + 1.5px);
    left: 50%;
    transform: translateX(-50%);
    background: white;
    border: 1.5px solid rgba(13,13,59,0.1);
    box-shadow: 0 16px 48px rgba(13,13,59,0.12), 0 2px 8px rgba(13,13,59,0.06);
    z-index: 200;
    min-width: 580px;
    animation: fadeSlide 0.18s ease;
  }

  .nav-item.open .mega-panel {
    display: block;
  }

  @keyframes fadeSlide {
    from { opacity: 0; transform: translateX(-50%) translateY(-6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .mega-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: 28px;
    gap: 8px 24px;
  }

  .mega-col {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 12px;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .mega-col:hover {
    background: rgba(13,13,59,0.03);
  }

  .mega-title {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--navy);
    text-decoration: none;
    margin-bottom: 8px;
    display: block;
    line-height: 1.3;
  }

  .mega-title:hover { color: var(--purple); }

  .mega-link {
    display: block;
    font-size: 0.82rem;
    color: rgba(13,13,59,0.6);
    text-decoration: none;
    padding: 3px 0;
    line-height: 1.4;
    transition: color 0.1s;
  }

  .mega-link:hover {
    color: var(--navy);
  }

  /* ── CTAs ── */
  #nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: 24px;
    flex-shrink: 0;
  }

  .cta-donate {
    background: var(--navy);
    color: var(--lime);
    font-size: 0.78rem;
    font-weight: 800;
    padding: 10px 22px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .cta-donate:hover { background: #1a1a5c; }

  .cta-join {
    color: var(--navy);
    font-size: 0.78rem;
    font-weight: 800;
    padding: 9px 20px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    border: 2px solid var(--navy);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .cta-join:hover {
    background: var(--navy);
    color: var(--cream);
  }

  /* ── Mobile toggle ── */
  #mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
  }

  #mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--navy);
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 1024px) {
    #nav-menu { display: none; }
    #nav-actions { display: none; }
    #mobile-toggle { display: flex; }
  }
</style>

<script>
  // Toggle dropdowns on click (works on both touch and desktop)
  document.querySelectorAll('.nav-trigger').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const item = btn.closest('.nav-item');
      const isOpen = item.classList.contains('open');

      // Close all others
      document.querySelectorAll('.nav-item.open').forEach(i => i.classList.remove('open'));

      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      } else {
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Close when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-item.open').forEach(i => {
      i.classList.remove('open');
      i.querySelector('[aria-expanded]')?.setAttribute('aria-expanded', 'false');
    });
  });

  // Close on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.nav-item.open').forEach(i => i.classList.remove('open'));
    }
  });
</script>
