---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Donate — Level Up"
  description="Support Level Up's feminist campaigns for gender justice in the UK."
>
  <section class="bg-red-brand px-16 py-24">
    <div class="section-label" style="color:rgba(255,255,255,0.7)">Support Our Work</div>
    <h1 class="text-8xl font-bold tracking-tight2 leading-display text-white mt-2 max-w-2xl">
      Fuel the Movement
    </h1>
    <p class="text-xl font-light text-white/80 tracking-tight2 leading-relaxed2 max-w-lg mt-6">
      Every donation directly funds our campaigns, community trainings, and feminist infrastructure. No donation is too small.
    </p>
  </section>

  <section class="bg-warm px-16 py-24 fade-up">
    <div class="max-w-2xl">
      <h2 class="text-4xl font-bold tracking-tight2 leading-display mb-8">Make a donation</h2>
      <p class="text-lg font-light text-[#444] tracking-tight2 leading-relaxed2 mb-10">
        Donations are processed securely via Mollie. You can make a one-time gift or set up a monthly contribution to sustain our work long-term.
      </p>
      <a href="https://welevelup.org/donate/" class="btn-primary text-xl px-12 py-5">
        Donate Now →
      </a>
    </div>
  </section>
</Layout>
