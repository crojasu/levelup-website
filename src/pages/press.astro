---
import Layout from '../layouts/Layout.astro';

const categories = [
  'All',
  'Abortion is Healthcare',
  'Domestic Abuse in Media',
  'Toxic Chemicals in Hair Relaxers',
  'Sexual Violence in Football',
  'Pregnancy in Prison',
  'Other',
];

const articles = [
  { title: "Prisoners who gave birth in handcuffs sue Ministry of Justice", outlet: "The Times", date: "May 30, 2025", category: "Pregnancy in Prison", url: "https://www.thetimes.com/article/85026ca4-a398-41a2-838e-4917f6595e2b" },
  { title: "Black women call for a ban on toxic hair products linked to cancer", outlet: "Voice Online", date: "May 28, 2025", category: "Toxic Chemicals in Hair Relaxers", url: "https://www.voice-online.co.uk/news/uk-news/2025/05/27/black-women-call-for-a-ban-on-toxic-hair-products-linked-to-cancer/" },
  { title: "Sentencing of pregnant women: a 21st century approach", outlet: "Counsel Magazine", date: "Mar 15, 2025", category: "Pregnancy in Prison", url: "https://www.counselmagazine.co.uk/articles/sentencing-of-pregnant-women-a-21st-century-approach" },
  { title: "Pregnant in prison: 'When I thought my baby had died nobody seemed to care'", outlet: "Metro", date: "Feb 22, 2025", category: "Pregnancy in Prison", url: "https://metro.co.uk/2025/02/22/pregnant-prison-i-thought-baby-died-treated-like-inconvenience-22578382/" },
  { title: "Alarming data reveals high diabetes risk for pregnant women in English jails", outlet: "The Guardian", date: "Feb 23, 2025", category: "Pregnancy in Prison", url: "https://www.theguardian.com/society/2025/feb/23/alarming-data-reveals-high-diabetes-risk-for-pregnant-women-in-english-jails" },
  { title: "Prisoners forced to give birth handcuffed to male officers", outlet: "The Times", date: "Feb 21, 2025", category: "Pregnancy in Prison", url: "https://www.thetimes.com/uk/crime/article/pregnant-women-prison-birth-handcuffed-male-officers-5f0698ks8" },
  { title: "'Prison will never be a safe place to be pregnant' – campaigner", outlet: "Channel 4 News", date: "Feb 19, 2025", category: "Pregnancy in Prison", url: "https://www.channel4.com/news/prison-will-never-be-a-safe-place-to-be-pregnant-campaigner" },
  { title: "The truth about hair relaxers: in the US, lawsuits over cancer. In Africa, soaring sales", outlet: "The Guardian", date: "Apr 10, 2024", category: "Toxic Chemicals in Hair Relaxers", url: "https://www.theguardian.com/global-development/2024/apr/10/black-women-beauty-hair-relaxers" },
  { title: "The #NoMoreLyes Hair Relaxer Petition, Explained", outlet: "Bustle", date: "Feb 20, 2024", category: "Toxic Chemicals in Hair Relaxers", url: "https://www.bustle.com/wellness/the-no-more-lyes-hair-relaxer-petition-explained" },
  { title: "Fewer pregnant women to be jailed after major shift in sentencing policy", outlet: "Mirror", date: "Mar 18, 2024", category: "Pregnancy in Prison", url: "https://www.mirror.co.uk/news/uk-news/prisoner-biting-umbilical-cord-cell-32379333" },
  { title: "Premier League teams are playing footballers facing abuse claims", outlet: "BBC News", date: "Nov 30, 2023", category: "Sexual Violence in Football", url: "https://www.bbc.com/news/uk-67508310" },
  { title: "A mother's fight for justice after baby dies in prison", outlet: "Channel 4 News", date: "Nov 14, 2023", category: "Pregnancy in Prison", url: "https://www.channel4.com/news/a-mothers-fight-for-justice-after-baby-dies-in-prison" },
  { title: "L'Oréal urged to withdraw hair relaxers after studies find cancer risk", outlet: "The Guardian", date: "Apr 21, 2023", category: "Toxic Chemicals in Hair Relaxers", url: "https://www.theguardian.com/society/2023/apr/21/loreal-urged-to-withdraw-hair-relaxers-after-studies-find-cancer-risk" },
  { title: "Why people are suing L'Oréal over hair relaxers", outlet: "BBC News", date: "Apr 24, 2023", category: "Toxic Chemicals in Hair Relaxers", url: "https://www.bbc.com/news/newsbeat-65189531" },
  { title: "Cristiano Ronaldo: plane banner protest as striker returns to Manchester United", outlet: "The Guardian", date: "Sep 11, 2021", category: "Sexual Violence in Football", url: "https://www.theguardian.com/football/2021/sep/11/cristiano-ronaldo-plane-banner-protest-as-striker-returns-to-manchester-united" },
  { title: "FA and Premier League urged to help tackle gender-based violence", outlet: "The Guardian", date: "Feb 5, 2022", category: "Sexual Violence in Football", url: "https://www.theguardian.com/society/2022/feb/05/fa-and-premier-league-urged-to-help-tackle-gender-based-violence" },
  { title: "Majority of Black women experienced 'scalp burns or hair loss' from relaxers", outlet: "Metro", date: "May 24, 2022", category: "Toxic Chemicals in Hair Relaxers", url: "https://metro.co.uk/2022/05/24/calls-for-brands-to-remove-dangerous-lye-from-black-hair-products-16697851/" },
  { title: "Campaigners Warn Media Is Failing Domestic Homicide Victims", outlet: "HuffPost UK", date: "Oct 8, 2018", category: "Domestic Abuse in Media", url: "https://www.huffingtonpost.co.uk/entry/domestic-violence-ipso-guidelines-campaign_uk_5bb92027e4b0876eda9e86d7" },
  { title: "Her husband murdered her. Then the media took away her dignity", outlet: "The Guardian", date: "Oct 8, 2018", category: "Domestic Abuse in Media", url: "https://www.theguardian.com/commentisfree/2018/oct/08/husband-murdered-media-melanie-clark-domestic-violence-deaths" },
  { title: "UK press regulators back feminist group's new guidelines on reporting domestic violence deaths", outlet: "Press Gazette", date: "Apr 16, 2019", category: "Domestic Abuse in Media", url: "https://pressgazette.co.uk/press-regulators-ipso-and-impress-back-level-up-new-guidelines-on-reporting-domestic-violence-deaths/" },
  { title: "HMP Bronzefield Surrey protest calls for 'no more babies in prison'", outlet: "BBC News", date: "Sep 25, 2022", category: "Pregnancy in Prison", url: "https://www.bbc.com/news/uk-england-surrey-63025914" },
  { title: "Jailed women in UK five times more likely to suffer stillbirths, data shows", outlet: "The Guardian", date: "Dec 5, 2021", category: "Pregnancy in Prison", url: "https://www.theguardian.com/society/2021/dec/05/jailed-women-in-uk-five-times-more-likely-to-suffer-stillbirths-data-shows" },
  { title: "Pregnant woman's jail sentence quashed in 'landmark' UK ruling", outlet: "The Guardian", date: "Jan 19, 2024", category: "Pregnancy in Prison", url: "https://www.theguardian.com/society/2024/jan/19/pregnant-woman-jail-sentence-quashed-in-landmark-uk-ruling" },
  { title: "Dozens of women accused of illegal abortions face police investigations", outlet: "The Independent", date: "Jun 28, 2023", category: "Abortion is Healthcare", url: "https://www.independent.co.uk/news/uk/home-news/abortions-police-investigation-women-b2358894.html" },
  { title: "T-shirts are all very well. But it's unions that win rights for women", outlet: "The Guardian", date: "Mar 8, 2019", category: "Other", url: "https://www.theguardian.com/commentisfree/2019/mar/08/women-feminism-trade-unions-feminism" },
  { title: "More than half of young women on Facebook have 'experienced harassment'", outlet: "Metro", date: "Mar 3, 2019", category: "Other", url: "https://metro.co.uk/2019/03/03/more-than-half-of-young-women-have-been-abused-on-facebook-8796171/" },
  { title: "How collective care can change society | TEDxLondonWomen", outlet: "TED", date: "2023", category: "Other", url: "https://bit.ly/3ZR4wTK" },
];

// Outlet logo colors (brand colours for known outlets)
const outletColor: Record<string, string> = {
  'The Guardian':   '#052962',
  'BBC News':       '#BB1919',
  'The Times':      '#1a1a1a',
  'Mirror':         '#d0021b',
  'Metro':          '#e60000',
  'Channel 4 News': '#2c2c2c',
  'The Independent':'#1a1a1a',
  'Voice Online':   '#C8102E',
};
---

<Layout
  title="Press Coverage — Level Up"
  description="Level Up in the news — press coverage of our campaigns for feminist gender justice in the UK."
>

  <!-- Header -->
  <section class="bg-black px-16 py-24">
    <div class="max-w-screen-2xl mx-auto">
      <div class="section-label">Media Coverage</div>
      <h1 class="text-8xl font-bold tracking-tight2 leading-display text-white mt-2">
        Press Coverage
      </h1>
      <p class="text-lg font-light text-white/50 tracking-tight2 leading-relaxed2 max-w-xl mt-6">
        Level Up's work covered by UK and international media.
      </p>
    </div>
  </section>

  <!-- Filter tabs -->
  <div class="bg-[#111] border-b border-white/10 px-16 overflow-x-auto">
    <div class="max-w-screen-2xl mx-auto flex gap-1 py-2">
      {categories.map((cat, i) => (
        <button
          class:list={[
            'press-filter px-5 py-2.5 text-xs font-medium uppercase tracking-widest2 whitespace-nowrap transition-colors cursor-pointer border-0',
            i === 0
              ? 'bg-red-brand text-white'
              : 'bg-transparent text-white/40 hover:text-white'
          ]}
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- Articles -->
  <section class="bg-warm px-16 py-16">
    <div class="max-w-screen-2xl mx-auto">
      <div class="flex flex-col gap-px" id="press-list">
        {articles.map(a => (
          <a
            href={a.url}
            target="_blank"
            rel="noopener noreferrer"
            class="press-item group flex items-start justify-between gap-8 bg-white p-7 no-underline border-l-[3px] border-transparent hover:border-red-brand transition-all duration-200"
            data-category={a.category}
          >
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span
                  class="text-[10px] font-bold uppercase tracking-widest2 px-2.5 py-1 text-white"
                  style={`background:${outletColor[a.outlet] ?? '#1a1a1a'}`}
                >
                  {a.outlet}
                </span>
                <span class="text-[11px] text-muted tracking-tight2">{a.category}</span>
              </div>
              <h3 class="text-base font-semibold text-black tracking-tight2 leading-display group-hover:text-red-brand transition-colors">
                {a.title}
              </h3>
            </div>
            <div class="text-right shrink-0">
              <div class="text-xs text-muted tracking-tight2 mb-2">{a.date}</div>
              <div class="text-red-brand text-sm group-hover:translate-x-1 transition-transform inline-block">→</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.press-filter');
  const items   = document.querySelectorAll<HTMLElement>('.press-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'All';

      // Update active button
      buttons.forEach(b => {
        b.classList.remove('bg-red-brand', 'text-white');
        b.classList.add('bg-transparent', 'text-white/40');
      });
      btn.classList.add('bg-red-brand', 'text-white');
      btn.classList.remove('bg-transparent', 'text-white/40');

      // Filter items
      items.forEach(item => {
        const match = cat === 'All' || item.dataset.category === cat;
        item.style.display = match ? 'flex' : 'none';
      });
    });
  });
</script>
