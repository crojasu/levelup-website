---
import Layout from '../layouts/Layout.astro';

const resources = [
  {
    category: "No More Lyes",
    color: "#C8102E",
    items: [
      { title: "#NoMoreLyes Relaxer Info Kit", desc: "Everything you need to know about toxic chemicals in hair relaxers.", href: "https://welevelup.org/nomorelyes-relaxer-info-kit/", type: "Guide" },
      { title: "Sign the Open Letter to L'Oréal", desc: "Join our call for L'Oréal to remove toxic ingredients from hair relaxers.", href: "https://welevelup.org/nomorelyes-open-letter-to-loreal/", type: "Action" },
      { title: "Share Your Hair Story", desc: "Tell us about your experience with hair relaxers.", href: "https://levelup.yourmovement.org/p/share-your-hair-story", type: "Community" },
    ],
  },
  {
    category: "Pregnancy in Prison",
    color: "#8B0A1E",
    items: [
      { title: "Pregnancy in Prison Resources", desc: "Research, reports, and evidence on pregnancy in prison in the UK.", href: "https://welevelup.org/pp-resources/", type: "Research" },
      { title: "Legal Toolkit for Practitioners", desc: "A toolkit for legal professionals representing pregnant women in the criminal justice system.", href: "https://piptoolkit.squarespace.com/", type: "Toolkit" },
    ],
  },
  {
    category: "Media Guidelines — Domestic Abuse",
    color: "#0A0A0A",
    items: [
      { title: "Media Guidelines on Reporting Domestic Abuse Deaths", desc: "The UK's first guidelines for journalists on how to report domestic homicides with dignity.", href: "https://welevelup.org/active-campaigns/media-guidelines-domestic-abuse/", type: "Guidelines" },
      { title: "Resources for Journalists", desc: "Supporting materials and background research for the Dignity for Dead Women campaign.", href: "https://welevelup.org/ddw-resources/", type: "Resource" },
    ],
  },
  {
    category: "Abortion is Healthcare",
    color: "#C8102E",
    items: [
      { title: "Abortion is Healthcare Resources & Media Guidelines", desc: "Resources for media, campaigners, and advocates on abortion decriminalisation.", href: "https://welevelup.org/abortion-is-healthcare-resources/", type: "Resource" },
      { title: "Share Your Abortion Story", desc: "Add your story to our community archive.", href: "https://welevelup.org/surveys/abortion-stories-complete/", type: "Community" },
    ],
  },
  {
    category: "We Protect Us",
    color: "#8B0A1E",
    items: [
      { title: "Sign Up for Bystander Intervention Trainings", desc: "Free monthly workshops on how to safely intervene in harassment and police violence.", href: "https://levelup.yourmovement.org/p/we-protect-us", type: "Training" },
    ],
  },
];
---

<Layout
  title="Resources — Level Up"
  description="Toolkits, guides, media guidelines, and research from Level Up's feminist campaigns for gender justice in the UK."
>

  <!-- Header -->
  <section class="bg-black px-16 py-24">
    <div class="max-w-screen-2xl mx-auto">
      <div class="section-label">Tools & Research</div>
      <h1 class="text-8xl font-bold tracking-tight2 leading-display text-white mt-2">
        Resources
      </h1>
      <p class="text-lg font-light text-white/50 tracking-tight2 leading-relaxed2 max-w-xl mt-6">
        Toolkits, guides, media guidelines, and research from our campaigns.
      </p>
    </div>
  </section>

  <!-- Resources -->
  <section class="bg-warm px-16 py-20">
    <div class="max-w-screen-2xl mx-auto flex flex-col gap-16">
      {resources.map(group => (
        <div class="fade-up">
          <!-- Category header -->
          <div class="flex items-center gap-4 mb-6">
            <div class="w-3 h-3 rounded-full" style={`background:${group.color}`}></div>
            <h2 class="text-xs font-bold uppercase tracking-widest2 text-black">{group.category}</h2>
          </div>

          <!-- Items grid -->
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px">
            {group.items.map(item => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white p-8 no-underline border-t-[3px] border-transparent hover:border-red-brand transition-all duration-200 block"
              >
                <div
                  class="text-[10px] font-bold uppercase tracking-widest2 text-white px-2.5 py-1 inline-block mb-5"
                  style={`background:${group.color}`}
                >
                  {item.type}
                </div>
                <h3 class="text-base font-semibold text-black tracking-tight2 leading-display mb-3 group-hover:text-red-brand transition-colors">
                  {item.title}
                </h3>
                <p class="text-sm text-muted font-light tracking-tight2 leading-relaxed2 mb-5">
                  {item.desc}
                </p>
                <span class="text-xs font-semibold text-red-brand uppercase tracking-widest2 inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                  View resource →
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</Layout>
